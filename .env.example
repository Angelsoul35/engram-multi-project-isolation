# =========================================================
# engram cloud server — template de configuración
#
# Copiar a `.env` y popular con valores reales.
# `chmod 600 .env` después de editar.
# NUNCA commitear `.env` real (ya está en `.gitignore`).
#
# Generar tokens nuevos (48 chars alfanuméricos):
#   gen() { LC_ALL=C tr -dc 'A-Za-z0-9' </dev/urandom | head -c 48; echo; }
#   gen   # correr 4 veces, una por cada secreto
# =========================================================

# ---- engram cloud server ----

# Bearer token que TODO cliente engram debe enviar (Authorization: Bearer ...)
ENGRAM_CLOUD_TOKEN=changeme-48-chars-alphanumeric

# Token separado para el dashboard admin (NO compartir con devs)
ENGRAM_CLOUD_ADMIN=changeme-48-chars-alphanumeric

# Firma interna de JWTs — NO rotar sin parar el servicio antes
ENGRAM_JWT_SECRET=changeme-48-chars-alphanumeric

# Bind dentro del container (Docker mapea a 127.0.0.1:18080 en el host)
ENGRAM_CLOUD_HOST=0.0.0.0
ENGRAM_PORT=18080

# Allowlist de proyectos sincronizables (separar por coma, sin espacios).
# Empezar vacío y sumar a medida. Ejemplo: myproject,another-project,third-one
ENGRAM_CLOUD_ALLOWED_PROJECTS=

# ---- Postgres ----

POSTGRES_USER=engram
POSTGRES_PASSWORD=changeme-48-chars-alphanumeric
POSTGRES_DB=engram
